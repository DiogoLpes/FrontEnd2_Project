generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  password  String
  role      Role     @default(USER)
  phone     String?
  vehicles  Vehicle[]
  createdAt DateTime @default(now())
}

model Vehicle {
  id        Int      @id @default(autoincrement())
  plate     String   @unique
  brand     String?
  model     String?
  year      Int?
  fuel      FuelType?
  mileage   Int?
  owner     User     @relation(fields: [ownerId], references: [id])
  ownerId   Int
  services  Service[]
  createdAt DateTime @default(now())
}

model Service {
  id          Int      @id @default(autoincrement())
  type        ServiceType
  description String?
  date        DateTime
  mileage     Int?
  price       Float?
  status      ServiceStatus @default(PENDENTE)
  vehicle     Vehicle @relation(fields: [vehicleId], references: [id])
  vehicleId   Int
  createdAt   DateTime @default(now())
}

enum Role {
  USER
  ADMIN
}

enum FuelType {
  GASOLINA
  DIESEL
  HIBRIDO
  ELETRICO
}

enum ServiceType {
  REVISAO
  PNEUS
  OLEO
  TRAVOES
  DIAGNOSTICO
  OUTRO
}

enum ServiceStatus {
  PENDENTE
  EM_REPARACAO
  CONCLUIDO
}